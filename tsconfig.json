{
    "compilerOptions": {
        "jsx": "react",
        "target": "ES2021",
        "module":"NodeNext",
        "incremental": true,
        "sourceMap": true,
        "outDir": "dist",
        "skipDefaultLibCheck": true,
        "skipLibCheck": true,
        "experimentalDecorators": true,
        "emitDecoratorMetadata": true,
        "noUnusedLocals": true,
        "importHelpers": true,
        "jsxFactory": "XNode.create",
        "rootDir": "./src",
        "lib": [
            "ES2018",
            "ES2021.WeakRef",
            "esnext.disposable",
            "ES2021.String",
            "DOM"
        ]
    },
    "include": [
        "src/**/*"
    ],
    "exclude": [
		"node_modules",
		"tests"
    ]
}