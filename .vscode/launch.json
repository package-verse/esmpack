{
    "version": "0.2.0",
    "configurations": [
        {
            "type": "node",
            "request": "launch",
            "name": "Launch Program",
            "program": "${workspaceRoot}/dist/test.js",
            "outFiles": [
                "${workspaceRoot}/out/**/*.js"
            ]
        },
         {
            "name": "Attach to Process",
            "type": "node",
            "request": "attach",
            "port": 9229,
            "localRoot": "${workspaceRoot}",
            "outFiles": [
                "${workspaceFolder}/dist/**/*.js",
            ]
        }
    ]
}